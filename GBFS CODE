from queue import PriorityQueue

# Warehouse graph
graph = {
    'Entrance': ['Rack_A', 'Rack_B'],
    'Rack_A': ['Rack_C', 'Rack_D'],
    'Rack_B': ['Rack_E'],
    'Rack_C': ['Target_Rack'],
    'Rack_D': [],
    'Rack_E': ['Target_Rack'],
    'Target_Rack': []
}

# Heuristic values (Estimated distance to Target_Rack)
heuristic = {
    'Entrance': 7,
    'Rack_A': 5,
    'Rack_B': 4,
    'Rack_C': 2,
    'Rack_D': 6,
    'Rack_E': 1,
    'Target_Rack': 0
}

def greedy_best_first_search(start, goal):
    pq = PriorityQueue()
    pq.put((heuristic[start], start))

    visited = set()
    parent = {start: None}

    while not pq.empty():
        h, current = pq.get()

        if current in visited:
            continue

        visited.add(current)

        print("Visited:", current)

        if current == goal:
            break

        for neighbor in graph[current]:
            if neighbor not in visited:
                parent[neighbor] = current
                pq.put((heuristic[neighbor], neighbor))

    # Construct path
    path = []
    node = goal

    while node is not None:
        path.append(node)
        node = parent[node]

    path.reverse()

    print("\nPath Found:")
    print(" -> ".join(path))

# Driver Code
greedy_best_first_search("Entrance", "Target_Rack")
